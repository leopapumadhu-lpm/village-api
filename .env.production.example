# ============================================
# Village API - Production Environment Template
# ============================================

# Server
PORT=3000
NODE_ENV=production

# Database (Required for production)
# Get from Neon, Railway, or Render:
DATABASE_URL="postgresql://user:password@host:port/dbname?sslmode=require"

# Redis (Required for production)  
# Get from Upstash or Redis Cloud:
REDIS_URL="rediss://user:password@host:port"

# Security (Generate strong secrets)
JWT_SECRET="your-64-char-random-hex-string-here-minimum-32-chars-long"
JWT_REFRESH_SECRET="your-second-64-char-random-hex-string-different-from-above"
WEBHOOK_SECRET="your-webhook-signing-secret-for-stripe"

# CORS & Frontend
CORS_ORIGINS="https://yourdomain.com,https://app.yourdomain.com"
FRONTEND_URL="https://app.yourdomain.com"

# Stripe (Required for payments)
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PREMIUM_PRICE_ID="price_..."
STRIPE_PRO_PRICE_ID="price_..."
STRIPE_UNLIMITED_PRICE_ID="price_..."

# Email (Required for notifications)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-real-email@gmail.com"
SMTP_PASS="your-real-app-password"
SENDER_EMAIL="noreply@yourdomain.com"

# Frontend
VITE_API_URL="https://api.yourdomain.com"
