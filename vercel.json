{
  "version": 2,
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    },
    { "src": "api/server.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "api/server.js" },
    { "src": "/admin/(.*)", "dest": "api/server.js" },
    { "src": "/auth/(.*)", "dest": "api/server.js" },
    { "src": "/b2b/(.*)", "dest": "api/server.js" },
    { "src": "/v1/(.*)", "dest": "api/server.js" },
    { "src": "/(.*)", "dest": "frontend/dist/$1", "status": 404 }
  ],
  "env": {
    "DATABASE_URL": "@database_url",
    "REDIS_URL": "@redis_url",
    "JWT_SECRET": "@jwt_secret",
    "PORT": "3000"
  },
  "functions": {
    "api/server.js": {
      "maxDuration": 30,
      "memory": 1024
    }
  }
}

