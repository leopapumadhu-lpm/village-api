{
  "version": 2,
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    },
    { "src": "api/server.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/api-docs/(.*)", "dest": "api/server.js" },
    { "src": "/api-spec", "dest": "api/server.js" },
    { "src": "/health", "dest": "api/server.js" },
    { "src": "/api/(.*)", "dest": "api/server.js" },
    { "src": "/admin/(.*)", "dest": "api/server.js" },
    { "src": "/auth/(.*)", "dest": "api/server.js" },
    { "src": "/b2b/(.*)", "dest": "api/server.js" },
    { "src": "/v1/(.*)", "dest": "api/server.js" },
    { "src": "/payments/(.*)", "dest": "api/server.js" },
    { "src": "/teams/(.*)", "dest": "api/server.js" },
    { "src": "/docs", "dest": "api/server.js" },
    { "src": "/(.*)", "dest": "frontend/dist/$1" }
  ],
  "env": {
    "NODE_ENV": "production"
  },
  "functions": {
    "api/server.js": {
      "maxDuration": 30,
      "memory": 1024
    }
  }
}

